const { GoogleGenerativeAI } = require('@google/generative-ai');
const Store = require('electron-store');
const store = new Store();
const { meetPrompt } = require('./prompt');

// Configuration constants
const MAX_RETRIES = 3;
const RETRY_DELAY = 1000; // 1 second
const DEFAULT_MAX_TOKENS = 2000;
const MODEL_NAME = 'gemini-2.5-flash';

class GeminiService {
  constructor() {
    this.genAI = null;
    this.model = null;
    this.meetChat = null;
    this.isInitialized = false;
    this.initializationPromise = null;
    
    // Initialize on creation
    this.initialize().catch(error => {
      console.error('Initial Gemini initialization failed:', error);
    });
  }

  /**
   * Main initialization method that sets up the Gemini AI client and chat
   */
  async initialize() {
    if (this.initializationPromise) {
      return this.initializationPromise;
    }

    const init = async () => {
      const apiKey = store.get('geminiApiKey');
      if (!apiKey) {
        throw new Error('No Gemini API key found. Please set it in settings.');
      }

      console.log('Initializing Gemini service...');
      
      // Initialize the Google Generative AI client
      this.genAI = new GoogleGenerativeAI(apiKey);
      
      // Configure the model
      this.model = this.genAI.getGenerativeModel({ 
        model: MODEL_NAME,
        generationConfig: {
          maxOutputTokens: DEFAULT_MAX_TOKENS,
          temperature: 0.7,
          topP: 0.95,
          topK: 40,
        },
        safetySettings: [
          { category: 'HARM_CATEGORY_HARASSMENT', threshold: 'BLOCK_MEDIUM_AND_ABOVE' },
          { category: 'HARM_CATEGORY_HATE_SPEECH', threshold: 'BLOCK_MEDIUM_AND_ABOVE' },
          { category: 'HARM_CATEGORY_SEXUALLY_EXPLICIT', threshold: 'BLOCK_MEDIUM_AND_ABOVE' },
          { category: 'HARM_CATEGORY_DANGEROUS_CONTENT', threshold: 'BLOCK_MEDIUM_AND_ABOVE' },
        ],
      });

      // Initialize the chat session
      await this._initializeChatSession();
      
      this.isInitialized = true;
      console.log('GeminiService: Successfully initialized with meet chat.');
      return true;
    };

    // Add retry logic
    this.initializationPromise = this._withRetry(init, {
      maxRetries: MAX_RETRIES,
      delay: RETRY_DELAY,
      taskName: 'Gemini initialization'
    });

    return this.initializationPromise;
  }

  /**
   * Initialize the chat session with system prompt
   */
  async _initializeChatSession() {
    console.log('Initializing Gemini chat session...');
    
    const chatConfig = {
      history: [],
      generationConfig: {
        maxOutputTokens: DEFAULT_MAX_TOKENS,
        temperature: 0.7,
        topP: 0.95,
        topK: 40,
      }
    };

    // Add system instruction if available
    if (meetPrompt) {
      chatConfig.systemInstruction = {
        role: 'model',
        parts: [{ text: meetPrompt }]
      };
      console.log('GeminiService: System instruction set for chat session');
    }
    
    this.meetChat = await this.model.startChat(chatConfig);
    this.chat = this.meetChat; // For backward compatibility
    
    console.log('GeminiService: Chat session initialized successfully');
    return this.meetChat;
  }

  /**
   * Generic retry wrapper for API calls
   */
  async _withRetry(fn, { maxRetries = 3, delay = 1000, taskName = 'Operation' } = {}) {
    let lastError;
    
    for (let attempt = 0; attempt <= maxRetries; attempt++) {
      try {
        return await fn();
      } catch (error) {
        lastError = error;
        const isLastAttempt = attempt === maxRetries;
        
        if (isLastAttempt) {
          console.error(`${taskName} failed after ${maxRetries} attempts:`, error);
          throw error;
        }
        
        const waitTime = delay * Math.pow(2, attempt);
        console.warn(`${taskName} attempt ${attempt + 1} failed, retrying in ${waitTime}ms...`);
        await new Promise(resolve => setTimeout(resolve, waitTime));
      }
    }
    
    throw lastError;
  }

  // Backward compatibility
  async initializeAI() {
    console.warn('initializeAI() is deprecated. Use initialize() instead.');
    return this.initialize();
  }

  // Backward compatibility
  async initializeMeetChat() {
    console.warn('initializeMeetChat() is deprecated. Chat is now initialized automatically.');
    return this.initialize();
  }

  async setApiKey(apiKey) {
    store.set('geminiApiKey', apiKey);
    
    // Re-initialize and replace the initialization promise.
    // Subsequent calls will wait on this new promise.
    this.initializationPromise = this.initializeAI();

    try {
      await this.initializationPromise;
      return true; // Return true on successful initialization
    } catch (error) {
      // The error is already logged in initializeAI
      return false; // Return false on failure
    }
  }

  /**
   * Sends a message to Gemini and returns the response
   * @param {string} prompt - The user's message
   * @param {string} [type='meet'] - The type of chat session to use
   * @returns {Promise<string>} The AI's response
   */
  async sendMessage(prompt, type = 'meet') {
    const startTime = Date.now();
    const messageId = `msg_${Date.now()}`;
    
    // Log the outgoing message (truncated for logs)
    const logPrefix = `[${messageId}]`;
    const logMessage = prompt.length > 100 ? `${prompt.substring(0, 100)}...` : prompt;
    console.log(`${logPrefix} Sending message to Gemini (${type}): "${logMessage}"`);

    try {
      // Ensure service is initialized
      if (!this.isInitialized) {
        console.log(`${logPrefix} Initializing Gemini service before sending message...`);
        await this.initialize();
      }

      // Validate chat session
      const chatSession = this.meetChat; // We only use meetChat now
      if (!chatSession) {
        throw new Error('Chat session is not initialized');
      }

      // Validate prompt
      if (typeof prompt !== 'string' || prompt.trim() === '') {
        throw new Error('Prompt must be a non-empty string');
      }

      // Send the message with retry logic
      const response = await this._withRetry(
        async () => {
          try {
            console.log(`${logPrefix} Sending to Gemini API...`);
            const result = await chatSession.sendMessage(prompt);
            
            // Log the raw response for debugging
            console.log(`${logPrefix} Raw API response:`, {
              hasResponse: !!result,
              responseKeys: result ? Object.keys(result) : 'no response',
              textExists: result?.response?.text ? 'yes' : 'no'
            });
            
            if (!result || !result.response) {
              throw new Error('Invalid response format from Gemini API');
            }
            
            const text = await result.response.text();
            console.log(`${logPrefix} Extracted text from response (${text?.length || 0} chars)`);
            
            if (!text) {
              throw new Error('Empty response text from Gemini API');
            }
            
            return text;
          } catch (error) {
            console.error(`${logPrefix} Error in API call:`, error);
            throw error; // Re-throw to allow retry logic to work
          }
        },
        {
          maxRetries: MAX_RETRIES,
          delay: RETRY_DELAY,
          taskName: `Gemini API call (${messageId})`
        }
      );

      // Log successful response
      const responseTime = Date.now() - startTime;
      const responsePreview = response ? 
        (response.length > 100 ? `${response.substring(0, 100)}...` : response) :
        '[EMPTY RESPONSE]';
        
      console.log(`${logPrefix} Received response in ${responseTime}ms: "${responsePreview}"`);
      
      // Ensure we always return a string
      return response || 'I apologize, but I couldn\'t generate a response. Please try again.';

    } catch (error) {
      const errorTime = Date.now() - startTime;
      console.error(`${logPrefix} Error after ${errorTime}ms:`, error);
      
      // Enhance error message with more context
      if (error.message.includes('API key not valid')) {
        throw new Error('Invalid Gemini API key. Please check your API key in settings.');
      } else if (error.message.includes('quota')) {
        throw new Error('API quota exceeded. Please check your Gemini API usage limits.');
      } else if (error.message.includes('model')) {
        throw new Error('Model unavailable. The specified Gemini model may not be accessible.');
      }
      
      throw new Error(`Failed to get response from Gemini: ${error.message}`);
    }
  }

  // Helper to determine if an error is retryable
  _isRetryableError(error, retryCount) {
    // Don't retry if we've exceeded max retries
    if (retryCount >= MAX_RETRIES) {
      return false;
    }
    
    // Network errors are retryable
    if (error.message?.toLowerCase().includes('network')) {
      return true;
    }
    
    // Rate limiting errors (429)
    if (error.message?.includes('429') || 
        error.message?.toLowerCase().includes('rate limit') ||
        error.message?.toLowerCase().includes('too many requests')) {
      return true;
    }
    
    // Server errors (5xx)
    if (error.code >= 500 || 
        error.message?.match(/5\d{2}/) ||
        error.message?.toLowerCase().includes('server') ||
        error.message?.toLowerCase().includes('service unavailable') ||
        error.message?.toLowerCase().includes('timeout')) {
      return true;
    }
    
    // Default to not retrying for other errors
    return false;
  }

  async clearConversation() {
    try {
      // Wait for any pending initialization
      if (this.initializationPromise) {
        await this.initializationPromise;
      }
      
      if (!this.isInitialized) {
        console.warn('Cannot clear conversation: Gemini is not initialized');
        return false;
      }
      
      console.log('Clearing Gemini meet chat conversation...');
      
      // Reset the meet chat
      this.meetChat = null;
      
      // Reinitialize the meet chat
      await this.initializeMeetChat();
      
      // Update the chat reference for backward compatibility
      this.chat = this.meetChat;
      
      console.log('Gemini meet chat conversation cleared');
      return true;
      
    } catch (error) {
      const errorMsg = `Failed to clear conversation: ${error.message}`;
      console.error(errorMsg, error);
      throw new Error(errorMsg);
    }
  }
}

module.exports = new GeminiService();
</file>

