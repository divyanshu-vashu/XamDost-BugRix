    // --- Core Functions ---
    function switchView(viewName) {
        // Hide all views
        document.querySelectorAll('.view').forEach(view => {
            view.style.display = 'none';
        });

        // Remove active class from all buttons
        document.querySelectorAll('.nav-btn').forEach(btn => {
