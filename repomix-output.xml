/* Basic reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* 
  FIX #1: THE CLICK-THROUGH PROBLEM
  Make the body and html non-interactive by default. Clicks will pass through them.
  This prevents the background from blocking clicks to the main app container.
*/
html, body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    background-color: transparent;
    color: #333;
    -webkit-user-select: none;
    user-select: none;
    overflow: hidden;
    height: 100%;
    width: 100%;
    margin: 0;
    padding: 0;
    position: relative;
    pointer-events: auto; /* Let clicks pass through */
}

/* 
  FIX #2: RE-ENABLE CLICKS ON THE MAIN APP CONTAINER
  Now, we make the main app container itself clickable again.
*/
#app {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
